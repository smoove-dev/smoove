{
  "version": "0.0.1",
  "configurations": [
    { "name": "demo", "runtimeExecutable": "pnpm", "runtimeArgs": ["dev"], "port": 5173 },
    {
      "name": "template-composition-ts",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--prefix",
        "templates/composition-ts",
        "--",
        "--port",
        "5180",
        "--strictPort"
      ],
      "port": 5180
    },
    {
      "name": "template-studio",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "templates/studio"],
      "port": 5174
    },
    {
      "name": "demo2",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "demo", "dev"],
      "port": 5174
    },
    {
      "name": "docs",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@smoove/docs", "dev"],
      "port": 5176,
      "autoPort": true
    },
    {
      "name": "docs-prod",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@smoove/docs", "start"],
      "port": 3000
    }
  ]
}
