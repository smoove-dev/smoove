{
  "name": "smoove",
  "version": "0.0.0",
  "private": true,
  "description": "Remotion-style timeline-driven animation for Konva.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "dev": "pnpm --filter demo run dev",
    "dev:docs": "pnpm --filter docs run dev",
    "check": "biome check .",
    "format": "biome format --write .",
    "bump": "node scripts/bump.mjs",
    "release": "pnpm build && pnpm -r --filter \"./packages/*\" publish --access public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "gl"
    ]
  }
}
