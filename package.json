{
  "name": "smoove",
  "version": "0.0.0",
  "private": true,
  "description": "Timeline-driven animation for Konva.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "dev": "pnpm --parallel --filter \"@smoove/kitchen-sink...\" run dev",
    "dev:app": "pnpm --filter @smoove/kitchen-sink run dev",
    "dev:docs": "pnpm --filter docs run dev",
    "check": "biome check .",
    "format": "biome format --write .",
    "test": "pnpm -r --if-present run test",
    "sync:templates": "node scripts/sync-composition.mjs",
    "release:version": "changeset version && node scripts/sync-template-versions.mjs && pnpm install --lockfile-only",
    "release:publish": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "gl"
    ]
  }
}
