{
  "name": "@konva-motion/studio",
  "version": "0.0.0",
  "description": "Composable React studio UI for konva-motion compositions — catalog, stage, timeline, props form, render dialogs.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles/studio.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b && pnpm run build:css",
    "build:css": "tailwindcss -i ./src/studio.css -o ./dist/styles/studio.css --minify",
    "dev": "concurrently -k \"tsc -b --watch --preserveWatchOutput\" \"tailwindcss -i ./src/studio.css -o ./dist/styles/studio.css --watch\"",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "signal-polyfill": "^0.2.2"
  },
  "peerDependencies": {
    "@konva-motion/core": "workspace:*",
    "@konva-motion/player": "workspace:*",
    "konva": ">=10",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.3.0"
  }
}
