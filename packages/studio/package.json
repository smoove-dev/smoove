{
  "name": "@smoove/studio",
  "version": "0.1.2",
  "description": "Composable React studio UI for smoove: catalog, stage, timeline, props form, and render dialogs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoove-dev/smoove.git",
    "directory": "packages/studio"
  },
  "homepage": "https://smoove.dev",
  "bugs": "https://github.com/smoove-dev/smoove/issues",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./styles.css": "./dist/styles/studio.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && pnpm run build:css",
    "build:css": "tailwindcss -i ./src/studio.css -o ./dist/styles/studio.css --minify",
    "dev": "concurrently -k \"tsc -b --watch --preserveWatchOutput\" \"tailwindcss -i ./src/studio.css -o ./dist/styles/studio.css --watch\"",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "signal-polyfill": "^0.2.2"
  },
  "peerDependencies": {
    "@smoove/core": "workspace:^",
    "@smoove/player": "workspace:^",
    "@smoove/renderer": "workspace:^",
    "konva": ">=10",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "@smoove/renderer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@smoove/renderer": "workspace:*",
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
