{
  "name": "@konva-motion/renderer",
  "version": "0.0.0",
  "description": "Headless server renderer for konva-motion — rasterizes a Composition with skia-canvas and encodes to video via Mediabunny (node-av / FFmpeg C API).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    },
    "./gl": {
      "types": "./dist/gl.d.ts",
      "import": "./dist/gl.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "example": "tsx examples/render-demo.ts",
    "example:mixer": "tsx examples/audio-mixer.ts"
  },
  "dependencies": {
    "@mediabunny/server": "^1.49.0",
    "mediabunny": "^1.49.0",
    "skia-canvas": "^3.0.8"
  },
  "optionalDependencies": {
    "gl": "^8.1.6"
  },
  "devDependencies": {
    "@konva-motion/transitions": "workspace:*",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2"
  },
  "peerDependencies": {
    "@konva-motion/core": "workspace:*",
    "@konva-motion/transitions": "workspace:*",
    "konva": ">=10"
  },
  "peerDependenciesMeta": {
    "@konva-motion/transitions": {
      "optional": true
    }
  }
}
