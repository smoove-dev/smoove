{
  "name": "@konva-motion/renderer",
  "version": "0.0.0",
  "description": "Headless server renderer for konva-motion — rasterizes a Composition with skia-canvas and encodes to video via ffmpeg.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "example": "tsx examples/render-demo.ts",
    "example:mixer": "tsx examples/audio-mixer.ts"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "skia-canvas": "^3.0.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2"
  },
  "peerDependencies": {
    "@konva-motion/core": "workspace:*",
    "konva": ">=10"
  }
}
