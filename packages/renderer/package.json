{
  "name": "@smoove/renderer",
  "version": "0.1.8",
  "description": "Headless video renderer for smoove. Rasterizes a Composition with skia-canvas and encodes with Mediabunny, no ffmpeg binary needed.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoove-dev/smoove.git",
    "directory": "packages/renderer"
  },
  "homepage": "https://smoove.dev",
  "bugs": "https://github.com/smoove-dev/smoove/issues",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    },
    "./gl": {
      "types": "./dist/gl.d.ts",
      "import": "./dist/gl.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "example": "tsx examples/render-demo.ts",
    "example:mixer": "tsx examples/audio-mixer.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@mediabunny/server": "^1.49.0",
    "mediabunny": "^1.49.0",
    "skia-canvas": "^3.0.8"
  },
  "optionalDependencies": {
    "gl": "^8.1.6"
  },
  "devDependencies": {
    "@smoove/transitions": "workspace:*",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2"
  },
  "peerDependencies": {
    "@smoove/core": "workspace:^",
    "@smoove/transitions": "workspace:^",
    "konva": ">=10"
  },
  "peerDependenciesMeta": {
    "@smoove/transitions": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
