{
  "name": "@smoove/core",
  "version": "0.1.0",
  "description": "Agnostic timeline-driven animation engine. Runs in browser or server; integrates with any render target (e.g. Konva).",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoove-dev/smoove.git",
    "directory": "packages/core"
  },
  "homepage": "https://smoove.dev",
  "bugs": "https://github.com/smoove-dev/smoove/issues",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "prepublishOnly": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "bezier-easing": "^2.1.0",
    "flexily": "^0.7.1",
    "mediabunny": "^1.49.0"
  },
  "peerDependencies": {
    "konva": ">=10"
  }
}
