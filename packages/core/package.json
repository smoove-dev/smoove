{
  "name": "@smoove/core",
  "version": "0.3.1",
  "description": "A timeline-driven animation engine for Konva. Runs in the browser or on the server and renders to any target.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoove-dev/smoove.git",
    "directory": "packages/core"
  },
  "homepage": "https://smoove.dev",
  "bugs": "https://github.com/smoove-dev/smoove/issues",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "prepublishOnly": "pnpm build",
    "dev": "tsc -b --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "bezier-easing": "^2.1.0",
    "flexily": "^0.7.1"
  },
  "peerDependencies": {
    "konva": ">=10"
  }
}
