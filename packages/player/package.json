{
  "name": "@konva-motion/player",
  "version": "0.0.0",
  "description": "Lit web components that play a konva-motion Composition like an HTML5 <video>.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/player.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b && cp src/player.css dist/player.css",
    "dev": "tsc -b --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@lit/context": "^1.1.3",
    "lit": "^3.2.1"
  },
  "peerDependencies": {
    "@konva-motion/core": "workspace:*",
    "konva": ">=9"
  }
}
