{
  "name": "@smoove/google-fonts",
  "version": "0.1.0",
  "description": "Typed, tree-shakeable Google Fonts for smoove — one Font subclass per family, loaded from the Google Fonts CDN. No build: imported as TS source.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoove-dev/smoove.git",
    "directory": "packages/google-fonts"
  },
  "homepage": "https://smoove.dev",
  "bugs": "https://github.com/smoove-dev/smoove/issues",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    "./manifest": "./src/manifest.ts",
    "./*": "./src/fonts/*.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "generate": "node --env-file-if-exists=.env --experimental-strip-types --no-warnings=ExperimentalWarning scripts/generate.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@smoove/core": "workspace:*",
    "konva": ">=10"
  },
  "devDependencies": {
    "@types/node": "^22.10.0"
  }
}
